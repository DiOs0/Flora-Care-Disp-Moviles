<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_welcome_gradient">

    <!-- LOGO -->
    <LinearLayout
        android:id="@+id/logoContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="28dp"
        android:layout_marginStart="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:src="@drawable/ic_logo"
            app:tint="@color/forest_green"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FloraCare"
            android:textColor="@color/forest_green"
            android:textStyle="bold"
            android:textSize="26sp"
            android:layout_marginStart="8dp"/>
    </LinearLayout>


    <!-- DECORACIÓN TRANSPARENTE -->
    <ImageView
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:src="@drawable/ic_leaf"
        android:alpha="0.04"
        app:tint="@color/forest_green"
        android:rotation="-20"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- IMAGEN DE LA PLANTA -->
    <ImageView
        android:id="@+id/imgPlant"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@drawable/planta_welcome"
        android:scaleType="fitCenter"
        app:layout_constraintTop_toBottomOf="@id/contentTop"
        app:layout_constraintBottom_toTopOf="@id/tvWelcomeText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.40"/>

    <!-- CONTENIDO SUPERIOR -->
    <LinearLayout
        android:id="@+id/contentTop"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginHorizontal="26dp"
        app:layout_constraintTop_toBottomOf="@id/logoContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- BADGE -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingHorizontal="22dp"
            android:background="@drawable/bg_welcome_badge">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_leaf"
                app:tint="@color/forest_green"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CUIDA LA VIDA EN CADA HOJA"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="@color/forest_dark"
                android:layout_marginStart="10dp"/>
        </LinearLayout>

        <!-- TITULO -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Donde las plantas florecen, la vida también"
            android:textColor="@color/forest_dark"
            android:textStyle="bold"
            android:textSize="34sp"
            android:gravity="center"
            android:lineSpacingExtra="2dp"
            android:layout_marginTop="24dp"/>

        <!-- DESCRIPCIÓN -->
        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Descubre el arte de la botánica. Aprende por qué cada gota cuenta y cómo la luz transforma tu hogar en un ecosistema saludable."
            android:textColor="@color/text_slate"
            android:textSize="16sp"
            android:gravity="center"
            android:lineSpacingExtra="3dp"
            android:layout_marginTop="14dp"/>
    </LinearLayout>

    <!-- FRASE-->
    <TextView
        android:id="@+id/tvWelcomeText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="“El riego adecuado es vida”"
        android:textStyle="italic"
        android:textColor="@color/forest_green"
        android:textSize="18sp"
        android:gravity="center"
        android:layout_marginHorizontal="28dp"
        android:layout_marginBottom="12dp"
        app:layout_constraintBottom_toTopOf="@id/bottomSection"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- PARTE INFERIOR -->
    <LinearLayout
        android:id="@+id/bottomSection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp"
        android:paddingBottom="34dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">


        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"/>

        <!-- BOTÓN -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnComenzar"
            android:layout_width="135dp"
            android:layout_height="54dp"
            android:text="Comenzar →"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="@color/forest_green"
            app:backgroundTint="@color/pale_green"
            app:cornerRadius="30dp"
            app:strokeColor="@color/forest_green"
            app:strokeWidth="1dp"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>