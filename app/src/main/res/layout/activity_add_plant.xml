<?xml version="1.0" encoding="utf-8"?>

<!-- JHON LAVERDE AÑADIR LAYOUT -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:android2="http://android.com"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.AddPlantActivity">


    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="415dp"
        android:layout_height="58dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0">

        <ImageView
            android:layout_width="58dp"
            android:layout_height="53dp"
            android:layout_marginStart="10dp"
            android:layout_marginTop="5dp"
            android:src="@drawable/ic_launcher_background" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginStart="110dp"
            android:gravity="center"
            android:text="FloraCare" />

        <ImageButton
            android:id="@+id/cerrarAplicacion"
            android:layout_width="77dp"
            android:layout_height="53dp"
            android:layout_marginStart="100dp"
            android:layout_marginTop="5dp"
            android:src="@mipmap/ic_launcher" />

    </LinearLayout>

    <TextView
        android:id="@+id/textView3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Registrar Planta"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.11"
        tools:layout_editor_absoluteX="-16dp" />

    <TextView
        android:id="@+id/textView2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Añade una nueva planta a tu ecosistema para comenzar a rastrear su crecimiento."
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView3"
        app:layout_constraintVertical_bias="0.03"
        tools:layout_editor_absoluteX="0dp" />

    <ImageView
        android:id="@+id/fotoTomada"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scaleType="centerCrop"
        android:layout_marginStart="100dp"
        android:layout_marginEnd="100dp"
        android:src="@drawable/ic_launcher_background"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView2"
        app:layout_constraintVertical_bias="0.075"
        tools:layout_editor_absoluteX="0dp" />

    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/txtNombrePlanta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nombre de la planta"
        android:layout_marginStart="15dp"
        android:layout_marginEnd="15dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/fotoTomada"
        app:layout_constraintVertical_bias="0.061"
        tools:layout_editor_absoluteX="1dp" />


    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/txtNameEspecie"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="especie"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/fotoTomada"
        app:layout_constraintVertical_bias="0.214"
        android:layout_marginStart="15dp"
        android:layout_marginEnd="15dp"
        tools:layout_editor_absoluteX="0dp" />

    <GridLayout
        android:id="@+id/gridLayout"
        android:layout_width="406dp"
        android:layout_height="125dp"
        android:columnCount="2"
        android:padding="4dp"
        android:rowCount="2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.724">

        <!-- Imagen 1 -->
        <ImageView
            android:layout_width="0dp"
            android:layout_height="58dp"
            android:layout_columnWeight="1"
            android:layout_gravity="fill"
            android:layout_margin="2dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_launcher_background" />

        <!-- Imagen 2 -->
        <ImageView
            android:layout_width="0dp"
            android:layout_height="58dp"
            android:layout_columnWeight="1"
            android:layout_gravity="fill"
            android:layout_margin="2dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_launcher_foreground" />

        <!-- Imagen 3 -->
        <ImageView
            android:layout_width="0dp"
            android:layout_height="58dp"
            android:layout_columnWeight="1"
            android:layout_gravity="fill"
            android:layout_margin="2dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_launcher_background" />

        <!-- Imagen 4 -->
        <ImageView
            android:layout_width="0dp"
            android:layout_height="58dp"
            android:layout_columnWeight="1"
            android:layout_gravity="fill"
            android:layout_margin="2dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_launcher_foreground" />

    </GridLayout>

    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/txtUltimoRiego"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/ultimo_riego"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/gridLayout"
        app:layout_constraintVertical_bias="0.204"
        android:layout_marginStart="15dp"
        android:layout_marginEnd="15dp"
        tools:layout_editor_absoluteX="0dp" />

    <Button
        android:id="@+id/btnGuardarPlanta"
        android:layout_width="390dp"
        android:layout_height="89dp"
        android:text="@string/guardar_planta"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintVertical_bias="1.0" />


</androidx.constraintlayout.widget.ConstraintLayout>