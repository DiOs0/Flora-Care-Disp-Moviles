<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9F5">

    <!-- HEADER: Fijo en la parte superior -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/ic_leaf"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_logo"
            app:tint="#2D5A27"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nueva Planta"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#2D5A27"
            android:layout_marginStart="8dp"
            app:layout_constraintStart_toEndOf="@id/ic_leaf"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/close_from_add_plant"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="#e7e9e1"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
            android:src="@drawable/close_add_plant"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ZONA DESLIZABLE: Toma el resto de la pantalla -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/headerLayout"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- EL SECRETO: Un solo LinearLayout envolviendo todo el formulario -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="40dp">

            <!-- FOTO DE LA PLANTA -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_gravity="center"
                android:layout_marginBottom="32dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/imgPlantPhoto"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#edefe7"
                    android:scaleType="centerCrop"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.ExtraLarge" />

                <androidx.camera.view.PreviewView
                    android:id="@+id/viewFinder"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FOTO DE LA PLANTA"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#72796e"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/btnCapturePhoto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:backgroundTint="#2D5A27"
                    app:tint="#FFFFFF"
                    android:src="@drawable/camera_add_plant"
                    app:elevation="4dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginEnd="-8dp"
                    android:layout_marginBottom="-8dp"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- NOMBRE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="17sp"
                android:text="Nombre de la Planta"
                android:textColor="#42493e"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:boxBackgroundColor="#f3f4ed"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxStrokeColor="#2D5A27"
                app:endIconMode="custom"
                app:endIconDrawable="@drawable/ic_logo">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPlantName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Ej: Sr. Helecho"
                    android:textColorHint="@color/black"
                    android:textSize="17sp"
                    android:inputType="textCapWords" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- ESPECIE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Especie"
                android:textColor="#42493e"
                android:textSize="17sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:boxBackgroundColor="#f3f4ed"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxStrokeColor="#2D5A27"
                app:endIconMode="custom"
                app:endIconDrawable="@drawable/ic_logo">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPlantSpecies"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Buscar especie..."
                    android:textColorHint="@color/black"
                    android:textSize="17sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp">

                <com.google.android.material.chip.ChipGroup
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleLine="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/especie_monstera"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="17sp"
                        android:text="Monstera"
                        app:chipBackgroundColor="#A3B18A"
                        android:textColor="#FFFFFF"/>
                    <com.google.android.material.chip.Chip
                        android:id="@+id/escape_suculenta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="17sp"
                        android:text="Suculenta"
                        app:chipBackgroundColor="#e2e3dc"
                        android:textColor="#42493e"/>
                    <com.google.android.material.chip.Chip
                        android:id="@+id/especie_cactus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="17sp"
                        android:text="Cactus"
                        app:chipBackgroundColor="#e2e3dc"
                        android:textColor="#42493e"/>
                </com.google.android.material.chip.ChipGroup>
            </HorizontalScrollView>

            <!-- UBICACIÓN -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ubicación"
                android:textSize="17sp"
                android:textColor="#42493e"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:layout_marginBottom="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnInterior"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_columnWeight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Interior"
                    android:textSize="17sp"
                    android:textColor="#191c18"
                    app:strokeColor="#2D5A27"
                    app:strokeWidth="2dp"
                    app:backgroundTint="#f3f4ed"
                    app:cornerRadius="16dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnExterior"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_columnWeight="1"
                    android:textSize="17sp"
                    android:layout_marginStart="8dp"
                    android:text="Exterior"
                    android:textColor="#191c18"
                    app:backgroundTint="#f3f4ed"
                    app:cornerRadius="16dp"
                    app:strokeWidth="2dp"/>


            </GridLayout>

            <!-- ÚLTIMO RIEGO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Último Riego"
                android:textSize="17sp"
                android:textColor="#42493e"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:boxBackgroundColor="#f3f4ed"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxStrokeColor="#2D5A27">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etLastWatered"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:clickable="true"
                    android:hint="DD/MM/AAAA" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- GUARDAR -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSavePlant"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Guardar Planta"
                android:textSize="20sp"
                app:backgroundTint="#2D5A27"
                app:cornerRadius="30dp"
                android:layout_marginBottom="16dp"/>

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone"
                android:layout_marginBottom="16dp"
                android:indeterminateTint="#2D5A27"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>