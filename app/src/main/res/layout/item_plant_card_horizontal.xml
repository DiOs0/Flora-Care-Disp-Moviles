<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardCornerRadius="20dp"
    app:strokeWidth="1.2dp"
    app:strokeColor="#EEF2EC"
    app:cardBackgroundColor="@color/white"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="10dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgPlantPhoto"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Medium"
            tools:src="@drawable/ic_launcher_foreground" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtPlantName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Monty"
                android:textColor="@color/forest_dark"
                android:textSize="22sp"
                android:textStyle="bold"
                tools:text="Monty" />

            <TextView
                android:id="@+id/txtPlantSpecies"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="MONSTERA DELICIOSA"
                android:textColor="#8C9C8A"
                android:textSize="11sp"
                android:textStyle="bold"
                tools:text="MONSTERA DELICIOSA" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvPlantCareLevel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="10dp"
                    android:paddingTop="4dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="4dp"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    tools:text="Medio" />

                <TextView
                    android:id="@+id/tvPlantTag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_tag_pill"
                    android:paddingStart="10dp"
                    android:paddingTop="4dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="4dp"
                    android:text="Interior"
                    android:textColor="@color/primary_green"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:visibility="visible"
                    tools:text="Interior" />
            </LinearLayout>

            <TextView
                android:id="@+id/txtLastWatered"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Último riego: --/--"
                android:textColor="@color/text_gray"
                android:textSize="13sp"
                tools:text="Último riego: 12/07" />

            <TextView
                android:id="@+id/txtNextWatering"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Próximo riego: --/--"
                android:textColor="@color/forest_green"
                android:textSize="15sp"
                android:textStyle="bold"
                tools:text="Próximo riego: 19/07" />

            <TextView
                android:id="@+id/txtWateringFrequency"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cada 7 días"
                android:textColor="@color/text_gray"
                android:textSize="12sp"
                tools:text="Cada 7 días" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp">

                <FrameLayout
                    android:id="@+id/badgeLayout"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true">

                    <View
                        android:id="@+id/badgeBackground"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/circle_alert_red" />

                    <ImageView
                        android:id="@+id/badgeIcon"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_menu_compass"
                        app:tint="@color/white" />
                </FrameLayout>

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/btnEditWatering"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_marginEnd="8dp"
                    android:layout_toStartOf="@id/badgeLayout"
                    android:layout_centerVertical="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="4dp"
                    android:src="@android:drawable/ic_menu_edit"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                    app:tint="@color/text_gray" />
            </RelativeLayout>

            <TextView
                android:id="@+id/txtHumidity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Humedad: 20%"
                android:textColor="@color/alert_red"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/txtWatered"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¡Regada!"
                android:textColor="#4CAF50"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

    <FrameLayout
        android:id="@+id/overlayConfirmWatering"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#A6FFFFFF"
        android:visibility="gone">

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/chkConfirmWatering"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Regar"
            android:textColor="@color/forest_green"
            android:textSize="16sp"
            android:textStyle="bold"
            app:buttonTint="@color/forest_green" />
    </FrameLayout>

</com.google.android.material.card.MaterialCardView>
