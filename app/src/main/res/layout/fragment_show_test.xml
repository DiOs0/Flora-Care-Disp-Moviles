<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    tools:context=".activities.Jhon_AddPlant.test.ShowTestFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Detalles de la Planta Registrada"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#2D3436"
            android:layout_marginBottom="24dp" />

        <!-- Card para los datos -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Nombre Común -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nombre Común"
                    android:textSize="12sp"
                    android:textColor="#636E72"
                    android:textAllCaps="true"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvShowCommonName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="---"
                    android:textSize="18sp"
                    android:textColor="#2D3436"
                    android:layout_marginBottom="16dp" />

                <!-- Nombre Científico -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nombre Científico"
                    android:textSize="12sp"
                    android:textColor="#636E72"
                    android:textAllCaps="true"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvShowScientificName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="---"
                    android:textSize="18sp"
                    android:textColor="#2D3436"
                    android:textStyle="italic"
                    android:layout_marginBottom="16dp" />

                <!-- Tipo -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tipo"
                    android:textSize="12sp"
                    android:textColor="#636E72"
                    android:textAllCaps="true"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvShowType"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="---"
                    android:textSize="16sp"
                    android:textColor="#2D3436"
                    android:layout_marginBottom="16dp" />

                <!-- Ciclo de Vida -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ciclo de Vida"
                    android:textSize="12sp"
                    android:textColor="#636E72"
                    android:textAllCaps="true"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvShowLifeCycle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="---"
                    android:textSize="16sp"
                    android:textColor="#2D3436"
                    android:layout_marginBottom="16dp" />

                <!-- Nivel de Cuidado -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nivel de Cuidado"
                    android:textSize="12sp"
                    android:textColor="#636E72"
                    android:textAllCaps="true"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvShowCareLevel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="---"
                    android:textSize="16sp"
                    android:textColor="#2D3436"
                    android:layout_marginBottom="16dp" />

                <!-- Descripción -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Descripción"
                    android:textSize="12sp"
                    android:textColor="#636E72"
                    android:textAllCaps="true"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvShowDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sin descripción disponible."
                    android:textSize="16sp"
                    android:textColor="#2D3436" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBackToTest"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:text="VOLVER AL REGISTRO"
            android:backgroundTint="#00FF87"
            android:textColor="#121414"
            android:textStyle="bold"
            app:cornerRadius="12dp" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>